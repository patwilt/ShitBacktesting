# ── Data ──────────────────────────────────────────────────────────────────────
# Ignore all CSVs and raw data by default (large files)
*.csv

# Ignore generated backtest result folders and raw market data
data/BT_*/
data/market_data/

# Allow the bundled sample dataset so the app runs on a fresh clone
# (git needs the directory un-ignored first, then the specific file)
!data/sample/
!data/sample/rolling_msci_strategies_results.csv

# ── Images ────────────────────────────────────────────────────────────────────
*.png
*.jpg
*.jpeg

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.DS_Store

# ── Legacy generated folders (kept for safety) ────────────────────────────────
BT_*/
CAGR_Plots/
CAGR Testing/
NewPlots/
